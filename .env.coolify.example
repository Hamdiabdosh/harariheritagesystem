# Coolify — Docker Compose environment variables
# Copy these into Coolify → Your Resource → Environment Variables
# Replace example values with your real domain and strong secrets.

# --- Required secrets ---
JWT_SECRET=replace-with-64-char-random-string
JWT_REFRESH_SECRET=replace-with-different-64-char-random-string

# --- Database (postgres + api services) ---
POSTGRES_USER=qirsmezgeb
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=qirsmezgeb

# --- Single public domain (no API subdomain) ---
# VITE_API_URL is baked into the frontend at BUILD time — redeploy after changing.
VITE_API_URL=https://heritage.example.com/api/v1
ALLOWED_ORIGINS=https://heritage.example.com

# --- Do NOT set in Coolify (breaks in-cluster networking) ---
# DB_URL
# PORT
# MEDIA_PATH
# POSTGRES_HOST
# POSTGRES_PORT
# SERVICE_URL_*
# SERVICE_FQDN_*   (Coolify auto-fills these for the caddy service)
