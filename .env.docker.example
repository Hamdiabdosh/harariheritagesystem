# Copy to .env before: docker compose up -d --build

# Database (used by postgres + api services)
POSTGRES_USER=qirsmezgeb
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=qirsmezgeb

# API secrets (required)
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string

# Single public domain — API is served under /api/v1 on the same host
VITE_API_URL=https://heritage.raafat.site/api/v1
ALLOWED_ORIGINS=https://heritage.raafat.site

# Do NOT set these in Coolify (they break Docker networking):
# DB_URL, PORT, MEDIA_PATH, SERVICE_URL_*, SERVICE_FQDN_* (except auto-filled on caddy)
