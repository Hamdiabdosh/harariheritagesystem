# Copy to .env before: docker compose up -d --build

# Database (used by postgres + api services)
POSTGRES_USER=qirsmezgeb
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=qirsmezgeb

# API secrets (required)
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string

# Public browser URL of the API (baked into frontend at build time)
# Local Docker: http://localhost:8080/api/v1
# Coolify:      https://api.your-domain.com/api/v1
VITE_API_URL=http://localhost:8080/api/v1

# Comma-separated origins allowed by the API CORS middleware
# Local Docker: http://localhost:3000
# Coolify:      https://your-domain.com
ALLOWED_ORIGINS=http://localhost:3000
