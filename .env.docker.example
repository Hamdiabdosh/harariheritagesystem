# Local full-stack Docker Compose
# Usage:
#   cp .env.docker.example .env
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build

# --- Database ---
POSTGRES_USER=qirsmezgeb
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=qirsmezgeb

# --- API secrets (required) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string

# --- URLs (local dev via Caddy on :8081) ---
VITE_API_URL=http://localhost:8081/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Do NOT set DB_URL, PORT, or MEDIA_PATH — the api entrypoint builds DB_URL
# from POSTGRES_* and uses /app/media inside the container.
