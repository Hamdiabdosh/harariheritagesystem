# Single-domain entrypoint: one public URL for the whole app.
# Coolify: assign your domain to the "caddy" service only (port 80).
:80 {
	handle /api/* {
		reverse_proxy api:8080
	}

	handle /health {
		reverse_proxy api:8080
	}

	handle /healthz {
		reverse_proxy api:8080
	}

	handle /media/* {
		reverse_proxy api:8080
	}

	handle {
		reverse_proxy frontend:3000
	}
}
